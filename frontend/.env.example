VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by frontend/api/analyze.js (a Vercel serverless function), never
# read by client code. Do NOT prefix this with VITE_: that prefix tells Vite to inline
# the value into the public JS bundle, which would expose it to every visitor.
GEMINI_API_KEY=your-gemini-api-key
# Optional model override, also server-only.
# GEMINI_MODEL=gemini-3.5-flash
